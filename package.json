{
  "name": "@entro314labs/apple-intelligence-sdk",
  "version": "0.5.3",
  "description": "Apple Intelligence provider for the Vercel AI SDK with pluggable transports (Tauri, Node, etc.)",
  "repository": {
    "type": "git",
    "url": "https://github.com/entro314-labs/apple-intelligence-sdk.git"
  },
  "homepage": "https://github.com/entro314-labs/apple-intelligence-sdk#readme",
  "bugs": {
    "url": "https://github.com/entro314-labs/apple-intelligence-sdk/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-sdk/provider": "beta",
    "@ai-sdk/provider-utils": "beta",
    "@tauri-apps/api": "^2.11.1",
    "json-schema": "^0.4.0"
  },
  "peerDependencies": {
    "ai": "7.0.0-beta.184"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "typescript": "rc"
  },
  "keywords": [
    "apple",
    "apple-intelligence",
    "vercel-ai-sdk",
    "tauri",
    "on-device",
    "provider"
  ],
  "license": "MIT"
}