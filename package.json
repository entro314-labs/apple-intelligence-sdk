{
  "name": "@entro314labs/apple-intelligence-sdk",
  "version": "0.4.0",
  "description": "Apple Intelligence provider for the Vercel AI SDK with pluggable transports (Tauri, Node, etc.)",
  "repository": {
    "type": "git",
    "url": "https://github.com/entro314-labs/apple-intelligence-sdk.git"
  },
  "homepage": "https://github.com/entro314-labs/apple-intelligence-sdk#readme",
  "bugs": {
    "url": "https://github.com/entro314-labs/apple-intelligence-sdk/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@tauri-apps/api": "^2.11.0",
    "json-schema": "^0.4.0"
  },
  "peerDependencies": {
    "ai": "^6.0.69"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "apple",
    "apple-intelligence",
    "vercel-ai-sdk",
    "tauri",
    "on-device",
    "provider"
  ],
  "license": "MIT"
}